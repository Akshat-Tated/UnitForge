# ============================================================
# UnitForge — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file. Only .env.example is committed.
#
# FREE USAGE:  Set LLM_PROVIDER=ollama (no API key needed)
# PAID USAGE:  Set LLM_PROVIDER=claude or openai (API key required)
# ============================================================


# ------------------------------------------------------------
# LLM Provider — choose one
# ------------------------------------------------------------
# Options: claude | openai | ollama
# Use "ollama" for completely free local usage (no API key needed)
LLM_PROVIDER=ollama


# ------------------------------------------------------------
# Claude (Anthropic) — best quality test generation
# Only required if LLM_PROVIDER=claude
# Get your key at: https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here


# ------------------------------------------------------------
# OpenAI — alternative paid provider
# Only required if LLM_PROVIDER=openai
# ------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o


# ------------------------------------------------------------
# Ollama — free, local, no API key needed
# Install Ollama: https://ollama.com
# Recommended models for test generation:
#   deepseek-coder-v2   → best quality, needs 16GB RAM
#   qwen2.5-coder:14b   → great quality, needs 10GB RAM
#   codellama:13b        → good for Python, needs 8GB RAM
#   qwen2.5-coder:7b    → lightweight, needs 6GB RAM
# Pull a model: ollama pull deepseek-coder-v2
# Only used if LLM_PROVIDER=ollama
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder-v2


# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=unitforge
POSTGRES_USER=unitforge
POSTGRES_PASSWORD=unitforge


# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379


# ------------------------------------------------------------
# Spring Boot Orchestrator
# ------------------------------------------------------------
SERVER_PORT=8080


# ------------------------------------------------------------
# UnitForge settings
# ------------------------------------------------------------
# Max parallel test agents running at once
MAX_AGENTS=4

# Max retries when generated tests fail
MAX_RETRY_ATTEMPTS=2

# Timeout per test agent (seconds)
AGENT_TIMEOUT_SECONDS=120
